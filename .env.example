# ── Educational-Video environment ──────────────────────────────────────

APP_ENV=development
PROJECT_NAME="AI Educational Video Platform"
VERSION=0.1.0
DEBUG=true
API_V1_STR=/api/v1

# CORS (comma-separated; defaults to "*")
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# ── LLM: Kimi K2.6 via the Sprints LiteLLM proxy (OpenAI-compatible) ─────────
# Every LLM call (video pipeline + template chatbot) routes through this proxy;
# no OpenAI account is required.
LITELLM_BASE_URL=https://management.sprints.ai/litellm
LITELLM_API_KEY=your-litellm-api-key
DEFAULT_MODEL=FW-Kimi-K2.6
LITELLM_USE_RESPONSE_FORMAT=true
LLM_MAX_TOKENS=12000
LLM_TEMPERATURE=0.2

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# Only used by the auth endpoints. Generate a strong random value for non-dev.
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# ── TTS: ElevenLabs ──────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID_ENGLISH=your-english-voice-id
ELEVENLABS_VOICE_ID_EGYPTIAN_ARABIC=your-egyptian-arabic-voice-id
# ── FREE VOICES ──────────────────────────────────────────────────────────
# ELEVENLABS_VOICE_ID_EGYPTIAN_ARABIC=JBFqnCBsd6RMkjVDRZzb #George
# ELEVENLABS_VOICE_ID_ENGLISH=cgSgspJ2msm6clMCkdW9 #Jessica

# ── PAID VOICES ──────────────────────────────────────────────────────────
# ELEVENLABS_VOICE_ID_EGYPTIAN_ARABIC=68MRVrnQAt8vLbu0FCzw #Mamdoh
# ELEVENLABS_VOICE_ID_EGYPTIAN_ARABIC=amSNjVC0vWYiE8iGimVb #Magdy
# ELEVENLABS_VOICE_ID_EGYPTIAN_ARABIC=EXAVITQu4vr4xnSDxMaL #Sarah


# ── Vector DB / RAG grounding ────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=edu_docs
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
RAG_ENABLED=true
RAG_CHROMA_PERSIST_DIR=.chroma
RAG_CHROMA_COLLECTION=technical_docs
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.35
# Optional metadata filters for seeded documentation stores. Leave blank to search all docs.
RAG_SOURCE=
RAG_VERSION=
RAG_DOC_TYPE=
# HF_TOKEN=hf_your_optional_token

# ── Pipeline evaluation / hallucination gate ────────────────────────────────
# DeepEval is the CI/runtime evaluator. The heuristic backend is only for local offline smoke checks.
PIPELINE_EVAL_BACKEND=deepeval
PIPELINE_EVAL_MODEL=
PIPELINE_EVAL_MAX_HALLUCINATION_RATE=0.05
PIPELINE_EVAL_FAITHFULNESS_THRESHOLD=0.95
PIPELINE_EVAL_RELEVANCY_THRESHOLD=0.60

# ── Pipeline storage / outputs ───────────────────────────────────────────────
VIDEO_DATA_DIR=./data
VIDEO_OUTPUT_DIR=./output
CHECKPOINT_DB_PATH=./data/jobs.db

# ── Frontend (Streamlit) ─────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000/api/v1

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── Optional: Langfuse tracing ───────────────────────────────────────────────
# LANGFUSE_TRACING_ENABLED=true
# LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
# LANGFUSE_SECRET_KEY=your-langfuse-secret-key
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_HOST=https://cloud.langfuse.com  # legacy alias

# ── Optional: Postgres (LangGraph checkpointing / auth persistence) ──────────
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# POSTGRES_DB=mydb
# POSTGRES_USER=myuser
# POSTGRES_PASSWORD=mypassword
# POSTGRES_POOL_SIZE=20
# POSTGRES_MAX_OVERFLOW=10

# ── Optional: Valkey/Redis cache (caching enabled when VALKEY_HOST is set) ────
# VALKEY_HOST=valkey
# VALKEY_PORT=6379
# VALKEY_DB=0
# VALKEY_PASSWORD=
# VALKEY_MAX_CONNECTIONS=20
# CACHE_TTL_SECONDS=60

# ── Optional: rate limiting ──────────────────────────────────────────────────
# RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
# RATE_LIMIT_CHAT="30 per minute"
# RATE_LIMIT_VIDEOS="60 per minute"
# RATE_LIMIT_RAG="60 per minute"
