# Copy this file to ".env" and fill in the values.

# --- LiteLLM proxy (OpenAI-compatible) -------------------------------------
LITELLM_API_KEY=
LITELLM_BASE_URL=
DEFAULT_MODEL=

# Task for the agent (or pass it as a CLI arg). Leave blank for the built-in default.
TASK_PROMPT=

# Send screenshots to the model (true, needs a multimodal model) or use the
# DOM/accessibility tree (false, for text-only models).
USE_VISION=true

# Run the browser without a visible window. Leave false locally to watch it;
# docker-compose forces this to true automatically.
HEADLESS=false

# Max Observe-Reason-Plan-Act steps before the loop stops.
MAX_STEPS=30

# Optional: path to a Chrome/Chromium binary. Leave unset locally to auto-detect
# your system Chrome. The Docker image sets this to /usr/bin/chromium for you.
# CHROME_PATH=/usr/bin/chromium
