{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vlm-render-mapper/render_plan_schema.json",
  "title": "VLM Render Plan",
  "description": "Structured render plan for programmatic video generation from browser-action sessions",
  "type": "object",
  "required": [
    "version",
    "metadata",
    "viewport",
    "frames",
    "timeline"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version (semver)"
    },
    "metadata": {
      "type": "object",
      "required": [
        "session_id",
        "recorded_at",
        "total_duration_ms",
        "frame_rate",
        "resolution"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time",
          "description": "UTC datetime at which the render plan was generated (renamed from created_at)"
        },
        "total_duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Total session duration in whole milliseconds"
        },
        "frame_rate": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "resolution": {
          "type": "object",
          "required": [
            "width",
            "height"
          ],
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "source_session_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "render_target": {
          "type": "string",
          "enum": [
            "ffmpeg",
            "remotion",
            "both"
          ],
          "default": "ffmpeg"
        }
      }
    },
    "viewport": {
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "device_pixel_ratio": {
          "type": "number",
          "default": 1.0
        }
      }
    },
    "frames": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/FrameDescriptor"
      },
      "minItems": 1
    },
    "timeline": {
      "type": "object",
      "required": [
        "segments"
      ],
      "properties": {
        "segments": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TimelineSegment"
          }
        },
        "total_duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "cursor_path": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/CursorKeyframe"
      }
    },
    "captions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Caption"
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Transition"
      }
    }
  },
  "definitions": {
    "FrameDescriptor": {
      "description": "Per-frame descriptor: one browser-action event mapped to render data",
      "type": "object",
      "required": [
        "frame_id",
        "source_action_index",
        "start_ms",
        "duration_ms",
        "screenshot_ref",
        "action"
      ],
      "properties": {
        "frame_id": {
          "type": "string"
        },
        "source_action_index": {
          "type": "integer",
          "minimum": 0,
          "description": "0-based index into the original session event list"
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Integer ms offset from session start (t=0)"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Integer display duration in ms"
        },
        "screenshot_ref": {
          "type": "string",
          "description": "Path or reference to the source screenshot for this frame"
        },
        "action": {
          "$ref": "#/definitions/Action"
        },
        "cursor": {
          "oneOf": [
            {
              "$ref": "#/definitions/CursorState"
            },
            {
              "type": "null"
            }
          ]
        },
        "highlight_regions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HighlightRegion"
          }
        },
        "zoom_region": {
          "oneOf": [
            {
              "$ref": "#/definitions/ZoomRegion"
            },
            {
              "type": "null"
            }
          ]
        },
        "caption_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Action": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "click",
            "double_click",
            "right_click",
            "hover",
            "scroll",
            "drag",
            "type",
            "key_press",
            "navigate",
            "page_load",
            "screenshot",
            "wait",
            "focus",
            "blur"
          ]
        },
        "target": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {},
        "coordinates": {
          "oneOf": [
            {
              "$ref": "#/definitions/Point"
            },
            {
              "type": "null"
            }
          ]
        },
        "modifiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ctrl",
              "shift",
              "alt",
              "meta"
            ]
          }
        },
        "scroll_delta": {
          "oneOf": [
            {
              "$ref": "#/definitions/Point"
            },
            {
              "type": "null"
            }
          ]
        },
        "drag_start": {
          "oneOf": [
            {
              "$ref": "#/definitions/Point"
            },
            {
              "type": "null"
            }
          ]
        },
        "drag_end": {
          "oneOf": [
            {
              "$ref": "#/definitions/Point"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "Point": {
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "CursorState": {
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "visible": {
          "type": "boolean",
          "default": true
        },
        "style": {
          "type": "string",
          "enum": [
            "default",
            "pointer",
            "text",
            "crosshair",
            "grab",
            "grabbing"
          ],
          "default": "default"
        }
      }
    },
    "CursorKeyframe": {
      "description": "Waypoint in the cursor path. timestamp_ms and duration_ms are segment-relative integers.",
      "type": "object",
      "required": [
        "timestamp_ms",
        "x",
        "y",
        "easing"
      ],
      "properties": {
        "timestamp_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Segment-relative integer ms offset from the start of this cursor segment"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "easing": {
          "type": "string",
          "enum": [
            "linear",
            "ease_in",
            "ease_out",
            "ease_in_out",
            "smoothstep",
            "spring"
          ],
          "description": "smoothstep uses t\u00b2 * (3 \u2212 2t)"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Travel time from previous keyframe in whole ms"
        }
      }
    },
    "HighlightRegion": {
      "type": "object",
      "required": [
        "region_id",
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "region_id": {
          "type": "string"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        },
        "color": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#FFD700"
        },
        "opacity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1,
          "default": 0.4
        },
        "border_radius": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "default": 4
        },
        "border_color": {
          "type": [
            "string",
            "null"
          ]
        },
        "border_width": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ZoomRegion": {
      "type": "object",
      "required": [
        "x",
        "y",
        "width",
        "height",
        "scale"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        },
        "scale": {
          "type": "number",
          "minimum": 1.0
        },
        "easing": {
          "type": "string",
          "enum": [
            "linear",
            "ease_in",
            "ease_out",
            "ease_in_out",
            "smoothstep"
          ],
          "default": "ease_in_out"
        },
        "transition_duration_ms": {
          "type": "integer",
          "minimum": 0,
          "default": 300
        }
      }
    },
    "Caption": {
      "type": "object",
      "required": [
        "caption_id",
        "text",
        "start_ms",
        "end_ms"
      ],
      "properties": {
        "caption_id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "end_ms": {
          "type": "integer",
          "minimum": 0
        },
        "position": {
          "type": "string",
          "enum": [
            "top",
            "bottom",
            "center",
            "top_left",
            "top_right",
            "bottom_left",
            "bottom_right"
          ],
          "default": "bottom"
        },
        "style": {
          "type": "object",
          "properties": {
            "font_size": {
              "type": "integer",
              "default": 24
            },
            "font_family": {
              "type": "string",
              "default": "Arial"
            },
            "color": {
              "type": "string",
              "default": "#FFFFFF"
            },
            "background_color": {
              "type": "string",
              "default": "#000000"
            },
            "background_opacity": {
              "type": "number",
              "default": 0.7
            },
            "padding": {
              "type": "integer",
              "default": 8
            }
          }
        }
      }
    },
    "Transition": {
      "type": "object",
      "required": [
        "transition_id",
        "type",
        "start_ms",
        "duration_ms"
      ],
      "properties": {
        "transition_id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "fade",
            "cut",
            "dissolve",
            "wipe_left",
            "wipe_right",
            "zoom_in",
            "zoom_out",
            "slide"
          ]
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "from_frame_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "to_frame_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "TimelineSegment": {
      "type": "object",
      "required": [
        "segment_id",
        "start_ms",
        "end_ms",
        "frame_ids"
      ],
      "properties": {
        "segment_id": {
          "type": "string"
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "end_ms": {
          "type": "integer",
          "minimum": 0
        },
        "frame_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "speed_multiplier": {
          "type": "number",
          "minimum": 0.1,
          "default": 1.0
        }
      }
    }
  }
}